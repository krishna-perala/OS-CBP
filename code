#include <iostream>
#include <string>
#include <vector>
using namespace std;
// Define enum for type of service
enum class ServiceType {
EmergencyCare,
ScheduledAppointments,
Diagnostics,
Pharmacy,
DineIn,
Takeaway,
Delivery
};
// Define enum for customer priority
enum class CustomerPriority {
Critical,
High,
Medium,
Low,
VIPRegular,
ReservationHolder,
WalkIn,
OnlineOrder
};
struct Process {
int process_id;
ServiceType service_type; // Type of service for the process
CustomerPriority priority; // Customer priority for the process
int sorting_value; // Value used for sorting
};
// Function to calculate sorting value based on service type and priority
int calculateSortingValue(ServiceType serviceType, CustomerPriority priority) {
// Assign scores based on service type
int serviceScore = 0;
switch (serviceType) {
case ServiceType::EmergencyCare:
serviceScore = 200;
break;
case ServiceType::ScheduledAppointments:
serviceScore = 100;
break;
case ServiceType::Diagnostics:
serviceScore = 80;
break;
case ServiceType::Pharmacy:
serviceScore = 60;
break;
case ServiceType::DineIn:
serviceScore = 90;
break;
case ServiceType::Takeaway:
serviceScore = 70;
break;
case ServiceType::Delivery:
serviceScore = 50;
break;
}
// Assign scores based on customer priority
int priorityScore = 0;
switch (priority) {
case CustomerPriority::Critical:
priorityScore = 150;
break;
case CustomerPriority::High:
priorityScore = 100;
break;
case CustomerPriority::Medium:
priorityScore = 50;
break;
case CustomerPriority::Low:
priorityScore = 25;
break;
case CustomerPriority::VIPRegular:
priorityScore = 120;
break;
case CustomerPriority::ReservationHolder:
priorityScore = 90;
break;
case CustomerPriority::WalkIn:
priorityScore = 60;
break;
case CustomerPriority::OnlineOrder:
priorityScore = 30;
break;
}
// Combine service score and priority score with weights
// Here, giving more weight to service type (e.g., 0.7) than to priority (e.g., 0.3)
double serviceWeight = 0.7;
double priorityWeight = 0.3;
int sortingValue = static_cast<int>(serviceScore * serviceWeight + priorityScore * priorityWeight);
return sortingValue;
}
// Merge function for merge sort (descending order)
void merge(vector<Process> &processes, int left, int mid, int right) {
int n1 = mid - left + 1;
int n2 = right - mid;
vector<Process> L(n1);
vector<Process> R(n2);
for (int i = 0; i < n1; i++)
L[i] = processes[left + i];
for (int j = 0; j < n2; j++)
R[j] = processes[mid + 1 + j];
int i = 0, j = 0, k = left;
while (i < n1 && j < n2) {
// Change comparison for descending order
if (L[i].sorting_value > R[j].sorting_value ||
(L[i].sorting_value == R[j].sorting_value && L[i].process_id < R[j].process_id)) {
processes[k] = L[i];
i++;
} else {
processes[k] = R[j];
j++;
}
k++;
}
while (i < n1) {
processes[k] = L[i];
i++;
k++;
}
while (j < n2) {
processes[k] = R[j];
j++;
k++;
}
}
// Merge sort function
void mergeSort(vector<Process> &processes, int left, int right) {
if (left >= right) {
return;
}
int mid = left + (right - left) / 2;
mergeSort(processes, left, mid);
mergeSort(processes, mid + 1, right);
merge(processes, left, mid, right);
}
