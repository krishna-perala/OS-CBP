void customerQueueManagement(string sysName, string custName) {
int n;
cout << "Enter the number of processes: ";
cin >> n;
vector<Process> processes(n);
// Display options based on system type
displayOptions(sysName);
// Input process details for
(int i = 0; i < n; i++) {
cout << "Process-" << i + 1 << ":\n"; processes[i].process_id
= i + 1;
int serviceChoice, priorityChoice;
cout << "Enter type of service (1-"; if
(sysName == "hospital")
cout << "4): ";
else if (sysName == "restaurant") cout
<< "3): ";
cin >> serviceChoice;
// Set service type based on user input
switch (serviceChoice) {
case 1:
processes[i].service_type = ServiceType::EmergencyCare;
break;
case 2:
processes[i].service_type = ServiceType::ScheduledAppointments; break;
case 3:
processes[i].service_type = ServiceType::Diagnostics;
break;
case 4:
if (sysName == "hospital")
processes[i].service_type = ServiceType::Pharmacy;
else if (sysName == "restaurant")
processes[i].service_type = ServiceType::Delivery;
break;
default:
processes[i].service_type = ServiceType::EmergencyCare; // Default to EmergencyCare
break;
}
cout << "Enter customer priority (1-4): ";
cin >> priorityChoice;
// Set customer priority based on user input
switch (priorityChoice) {
case 1:
processes[i].priority = CustomerPriority::Critical;
break;
case 2:
processes[i].priority = CustomerPriority::High;
break;
case 3:
processes[i].priority = CustomerPriority::Medium;
break;
case 4:
processes[i].priority = CustomerPriority::Low;
break;
default:
processes[i].priority = CustomerPriority::Low; // Default to Low priority
break;
}
// Calculate sorting value based on service type and priority
processes[i].sorting_value = calculateSortingValue(processes[i].service_type, processes[i].priority);
}
// Sort processes using merge sort based on sorting_value and process_id
mergeSort(processes, 0, n - 1);
cout << "\t" << sysName << " Queue Management\t\n";
cout << "Sequence of execution : ";
for (int i = 0; i < n; i++) {
if (i != n - 1)
cout << custName << "-" << processes[i].process_id << " --> ";
else
cout << custName << "-" << processes[i].process_id;
}
}
int main() {
string sysName, custName;
cout << "Enter System Name (hospital/restaurant):\n";
cin >> sysName;
cout << "Enter customer name\n";
cin >> custName;
customerQueueManagement(sysName, custName);
